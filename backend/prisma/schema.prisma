generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["partialIndexes"]
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Farm {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  slug        String   @unique
  description String?
  inviteCode  String   @unique @map("invite_code")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users         User[]
  fields        Field[]
  notifications Notification[]

  @@index([slug])
  @@map("farms")
}

model User {
  id             String         @id @default(uuid()) @db.Uuid
  email          String         @unique
  role           Role           @default(AGENT)
  fullName       String?        @map("full_name")
  phone          String?
  isActive       Boolean        @default(true) @map("is_active")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  fieldImages    FieldImage[]
  fieldUpdates   FieldUpdate[]  @relation("AgentUpdates")
  assignedFields Field[]        @relation("AgentFields")
  updatedFields  Field[]        @relation("FieldUpdatedBy")
  farm           Farm?          @relation(fields: [farmId], references: [id], onDelete: SetNull)
  farmId         String?        @map("farm_id") @db.Uuid
  notifications  Notification[]

  @@index([role])
  @@map("users")
}

model Location {
  id        String   @id @default(uuid()) @db.Uuid
  county    String
  subCounty String?  @map("sub_county")
  ward      String?
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  field     Field?

  @@index([county])
  @@index([county], map: "idx_locations_county")
  @@map("locations")
}

model Field {
  id            String         @id @default(uuid()) @db.Uuid
  name          String
  cropType      String         @map("crop_type")
  plantingDate  DateTime       @map("planting_date")
  currentStage  CropStage      @default(PLANTED) @map("current_stage")
  description   String?
  areaSize      Float?         @map("area_size")
  agentId       String?        @map("agent_id") @db.Uuid
  locationId    String         @unique @map("location_id") @db.Uuid
  coverImageUrl String?        @map("cover_image_url")
  lastUpdatedAt DateTime?      @map("last_updated_at")
  updatedById   String?        @map("updated_by_id") @db.Uuid
  isArchived    Boolean        @default(false) @map("is_archived")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  images        FieldImage[]
  updates       FieldUpdate[]
  agent         User?          @relation("AgentFields", fields: [agentId], references: [id])
  location      Location       @relation(fields: [locationId], references: [id], onDelete: Cascade)
  updatedBy     User?          @relation("FieldUpdatedBy", fields: [updatedById], references: [id])
  farm          Farm           @relation(fields: [farmId], references: [id])
  farmId        String         @map("farm_id") @db.Uuid
  notifications Notification[]

  @@index([agentId])
  @@index([agentId, isArchived])
  @@index([currentStage])
  @@index([isArchived])
  @@index([plantingDate])
  @@index([lastUpdatedAt])
  @@index([agentId], map: "idx_fields_agent_active", where: raw("(is_archived = false)"))
  @@index([currentStage], map: "idx_fields_stage_active", where: raw("(is_archived = false)"))
  @@map("fields")
}

model FieldUpdate {
  id         String    @id @default(uuid()) @db.Uuid
  fieldId    String    @map("field_id") @db.Uuid
  agentId    String    @map("agent_id") @db.Uuid
  stage      CropStage
  notes      String?
  imageUrl   String?   @map("image_url")
  observedAt DateTime  @map("observed_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  agent      User      @relation("AgentUpdates", fields: [agentId], references: [id], onDelete: Cascade)
  field      Field     @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@index([fieldId, observedAt(sort: Desc)])
  @@index([agentId])
  @@index([observedAt])
  @@index([fieldId, observedAt(sort: Desc)], map: "idx_field_updates_field_observed")
  @@map("field_updates")
}

model FieldImage {
  id           String   @id @default(uuid()) @db.Uuid
  fieldId      String   @map("field_id") @db.Uuid
  url          String
  caption      String?
  uploadedById String?  @map("uploaded_by_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  field        Field    @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])

  @@index([fieldId])
  @@index([uploadedById])
  @@map("field_images")
}

model Notification {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fieldId String? @map("field_id") @db.Uuid
  field   Field?  @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  farmId String @map("farm_id") @db.Uuid
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  type     NotificationType
  title    String
  message  String
  metadata Json?

  isRead Boolean   @default(false) @map("is_read")
  readAt DateTime? @map("read_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, farmId, createdAt(sort: Desc)])
  @@index([userId, isRead])
  @@index([farmId, createdAt(sort: Desc)])
  @@map("notifications")
}

enum Role {
  ADMIN
  AGENT
}

enum CropStage {
  PLANTED
  GROWING
  READY
  HARVESTED
}

enum NotificationType {
  FIELD_AT_RISK
  FIELD_COMPLETED
  FIELD_ASSIGNED
}
