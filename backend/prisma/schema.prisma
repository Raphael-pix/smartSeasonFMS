generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  AGENT
}

enum CropStage {
  PLANTED
  GROWING
  READY
  HARVESTED
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  role      Role     @default(AGENT)
  fullName  String?  @map("full_name")
  phone     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  assignedFields Field[]       @relation("AgentFields")
  fieldUpdates   FieldUpdate[] @relation("AgentUpdates")

  updatedFields Field[]      @relation("FieldUpdatedBy")
  fieldImages   FieldImage[]

  @@index([role])
  @@map("users")
}

model Location {
  id        String   @id @default(uuid()) @db.Uuid
  county    String
  subCounty String?  @map("sub_county")
  ward      String?
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  field Field?

  @@index([county])
  @@map("locations")
}

model Field {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  cropType     String    @map("crop_type")
  plantingDate DateTime  @map("planting_date")
  currentStage CropStage @default(PLANTED) @map("current_stage")
  description  String?
  areaSize     Float?    @map("area_size")

  agentId String? @map("agent_id") @db.Uuid
  agent   User?   @relation("AgentFields", fields: [agentId], references: [id], onDelete: SetNull)

  locationId String   @unique @map("location_id") @db.Uuid
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  coverImageUrl String? @map("cover_image_url")

  lastUpdatedAt DateTime? @map("last_updated_at")

  updatedById String? @map("updated_by_id") @db.Uuid
  updatedBy   User?   @relation("FieldUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  isArchived Boolean  @default(false) @map("is_archived")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  images  FieldImage[]
  updates FieldUpdate[]

  @@index([agentId])
  @@index([agentId, isArchived])
  @@index([currentStage])
  @@index([isArchived])
  @@index([plantingDate])
  @@index([lastUpdatedAt])
  @@map("fields")
}

model FieldUpdate {
  id      String @id @default(uuid()) @db.Uuid
  fieldId String @map("field_id") @db.Uuid
  agentId String @map("agent_id") @db.Uuid

  stage CropStage

  notes String?

  imageUrl String? @map("image_url")

  observedAt DateTime @map("observed_at")

  createdAt DateTime @default(now()) @map("created_at")

  field Field @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  agent User  @relation("AgentUpdates", fields: [agentId], references: [id], onDelete: Cascade)

  @@index([fieldId, observedAt(sort: Desc)])
  @@index([agentId])
  @@index([observedAt])
  @@map("field_updates")
}

model FieldImage {
  id      String @id @default(uuid()) @db.Uuid
  fieldId String @map("field_id") @db.Uuid

  url          String
  caption      String?
  uploadedById String? @map("uploaded_by_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  field      Field @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  uploadedBy User? @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([fieldId])
  @@index([uploadedById])
  @@map("field_images")
}
